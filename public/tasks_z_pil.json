[
  {
    "id": 1,
    "audio": "/audio/z_001.mp3",
    "text": "Как зовут отца Измаила?"
  },
  {
    "id": 2,
    "audio": "/audio/z_002.mp3",
    "text": "Чего у героя не осталось в кошельке?"
  },
  {
    "id": 3,
    "audio": "/audio/z_003.mp3",
    "text": "С какой стороны герой захотел посмотреть на мир?"
  },
  {
    "id": 4,
    "audio": "/audio/z_004.mp3",
    "text": "Какой месяц воцаряется в душе у героя?"
  },
  {
    "id": 5,
    "audio": "/audio/z_005.mp3",
    "text": "Перед чьими вывесками начал останавливаться герой?"
  },
  {
    "id": 6,
    "audio": "/audio/z_006.mp3",
    "text": "Куда пора отравляться герою?"
  },
  {
    "id": 7,
    "audio": "/audio/z_007.mp3",
    "text": "Кто бросается на меч?"
  },
  {
    "id": 8,
    "audio": "/audio/z_008.mp3",
    "text": "Чего люди не отдают себе?"
  },
  {
    "id": 9,
    "audio": "/audio/z_009.mp3",
    "text": "О каком городе говорит герой?"
  },
  {
    "id": 10,
    "audio": "/audio/z_010.mp3",
    "text": "Чем омывается величественный мол?"
  },
  {
    "id": 11,
    "audio": "/audio/z_011.mp3",
    "text": "На какой оконечности острова расположен парк?"
  },
  {
    "id": 12,
    "audio": "/audio/z_012.mp3",
    "text": "Какой день недели?"
  },
  {
    "id": 13,
    "audio": "/audio/z_013.mp3",
    "text": "Что созерцают смертные?"
  },
  {
    "id": 14,
    "audio": "/audio/z_014.mp3",
    "text": "Откуда прибыл корабль?"
  },
  {
    "id": 15,
    "audio": "/audio/z_015.mp3",
    "text": "К чему прикованы люди?"
  },
  {
    "id": 16,
    "audio": "/audio/z_016.mp3",
    "text": "Какие толпы устремляются сюда?"
  },
  {
    "id": 17,
    "audio": "/audio/z_017.mp3",
    "text": "К чему им нужно подобраться?"
  },
  {
    "id": 18,
    "audio": "/audio/z_018.mp3",
    "text": "Горожане какие?"
  },
  {
    "id": 19,
    "audio": "/audio/z_019.mp3",
    "text": "Что приведёт Вас вниз?"
  },
  {
    "id": 20,
    "audio": "/audio/z_020.mp3",
    "text": "К чему приведёт Вас человек?"
  },
  {
    "id": 21,
    "audio": "/audio/z_021.mp3",
    "text": "Что неотделимо друг от друга?"
  },
  {
    "id": 22,
    "audio": "/audio/z_022.mp3",
    "text": "Как называется река в штате Мэн?"
  },
  {
    "id": 23,
    "audio": "/audio/z_023.mp3",
    "text": "Какие стоят деревья?"
  },
  {
    "id": 24,
    "audio": "/audio/z_024.mp3",
    "text": "Чего достигает тропинка?"
  },
  {
    "id": 25,
    "audio": "/audio/z_025.mp3",
    "text": "Что бежит перед пастухом?"
  },
  {
    "id": 26,
    "audio": "/audio/z_026.mp3",
    "text": "Чем усеяна трава?"
  },
  {
    "id": 27,
    "audio": "/audio/z_027.mp3",
    "text": "Если бы Ниагара была чем?"
  },
  {
    "id": 28,
    "audio": "/audio/z_028.mp3",
    "text": "В чём нуждался поэт из Теннеси?"
  },
  {
    "id": 29,
    "audio": "/audio/z_029.mp3",
    "text": "Чем начинает бредить мальчишка?"
  },
  {
    "id": 30,
    "audio": "/audio/z_030.mp3",
    "text": "Что сделали берега?"
  },
  {
    "id": 31,
    "audio": "/audio/z_031.mp3",
    "text": "Кто считал море священным?"
  },
  {
    "id": 32,
    "audio": "/audio/z_032.mp3",
    "text": "В чём Нарцисс увидел образ?"
  },
  {
    "id": 33,
    "audio": "/audio/z_033.mp3",
    "text": "Где мы видим образ фантома жизни?"
  },
  {
    "id": 34,
    "audio": "/audio/z_034.mp3",
    "text": "Что даёт себя чувствовать?"
  },
  {
    "id": 35,
    "audio": "/audio/z_035.mp3",
    "text": "Что нужно для того, чтобы стать пассажиром?"
  },
  {
    "id": 36,
    "audio": "/audio/z_036.mp3",
    "text": "Чем страдают пассажиры?"
  },
  {
    "id": 37,
    "audio": "/audio/z_037.mp3",
    "text": "Что питает герой?"
  },
  {
    "id": 38,
    "audio": "/audio/z_038.mp3",
    "text": "Какая должность – должность кока?"
  },
  {
    "id": 39,
    "audio": "/audio/z_039.mp3",
    "text": "Кого не любит жарить герой?"
  },
  {
    "id": 40,
    "audio": "/audio/z_040.mp3",
    "text": "Что мы находим в пекарнях-пирамидах?"
  },
  {
    "id": 41,
    "audio": "/audio/z_041.mp3",
    "text": "Кем герой идёт в плаванье?"
  },
  {
    "id": 42,
    "audio": "/audio/z_042.mp3",
    "text": "Чувства чего это задевает?"
  },
  {
    "id": 43,
    "audio": "/audio/z_043.mp3",
    "text": "Каких учеников ты повергал в трепет?"
  },
  {
    "id": 44,
    "audio": "/audio/z_044.mp3",
    "text": "Что со временем теряет отвар?"
  },
  {
    "id": 45,
    "audio": "/audio/z_045.mp3",
    "text": "Кто просит взять метлу?"
  },
  {
    "id": 46,
    "audio": "/audio/z_046.mp3",
    "text": "Как зовут архангела?"
  },
  {
    "id": 47,
    "audio": "/audio/z_047.mp3",
    "text": "Капитаны какие?"
  },
  {
    "id": 48,
    "audio": "/audio/z_048.mp3",
    "text": "Что чувствует каждый в обществе?"
  },
  {
    "id": 49,
    "audio": "/audio/z_049.mp3",
    "text": "Кто сам должен платить?"
  },
  {
    "id": 50,
    "audio": "/audio/z_050.mp3",
    "text": "Какую кару представляет акт уплаты?"
  },
  {
    "id": 51,
    "audio": "/audio/z_051.mp3",
    "text": "Куда не удастся проникнуть богатому человеку?"
  },
  {
    "id": 52,
    "audio": "/audio/z_052.mp3",
    "text": "С чего ветры дуют чаще?"
  },
  {
    "id": 53,
    "audio": "/audio/z_053.mp3",
    "text": "Кого опережает простой народ?"
  },
  {
    "id": 54,
    "audio": "/audio/z_054.mp3",
    "text": "На чём в этот раз герой решил пойти в море?"
  },
  {
    "id": 55,
    "audio": "/audio/z_055.mp3",
    "text": "Кто воздействует на поступки героя?"
  },
  {
    "id": 56,
    "audio": "/audio/z_056.mp3",
    "text": "Каким номером служило плаванье героя на китобойном судне?"
  },
  {
    "id": 57,
    "audio": "/audio/z_057.mp3",
    "text": "Где кровавая резня?"
  },
  {
    "id": 58,
    "audio": "/audio/z_058.mp3",
    "text": "Какую роль назначили герою на китобойном судне?"
  },
  {
    "id": 59,
    "audio": "/audio/z_059.mp3",
    "text": "На основе свободы чего поступил герой?"
  },
  {
    "id": 60,
    "audio": "/audio/z_060.mp3",
    "text": "Чего не могло не возбуждать чудовище?"
  },
  {
    "id": 61,
    "audio": "/audio/z_061.mp3",
    "text": "В чём всё это укрепляло героя?"
  },
  {
    "id": 62,
    "audio": "/audio/z_062.mp3",
    "text": "По каким водам любит плавать герой?"
  },
  {
    "id": 63,
    "audio": "/audio/z_063.mp3",
    "text": "Что герой тонко чувствует?"
  },
  {
    "id": 64,
    "audio": "/audio/z_064.mp3",
    "text": "На каком судне герой был готов предпринять путешествие?"
  },
  {
    "id": 65,
    "audio": "/audio/z_065.mp3",
    "text": "Процессии кого потянулись перед героем?"
  },
  {
    "id": 66,
    "audio": "/audio/z_066.mp3",
    "text": "Куда вздымался призрак?"
  },
  {
    "id": 67,
    "audio": "/audio/z_067.mp3",
    "text": "К какому мысу отправился герой?"
  },
  {
    "id": 68,
    "audio": "/audio/z_068.mp3",
    "text": "В каком месяце было дело?"
  },
  {
    "id": 69,
    "audio": "/audio/z_069.mp3",
    "text": "Что сделал маленький пакетбот?"
  },
  {
    "id": 70,
    "audio": "/audio/z_070.mp3",
    "text": "Чему не хотел следовать герой?"
  },
  {
    "id": 71,
    "audio": "/audio/z_071.mp3",
    "text": "Кто был впервые вытащен на берег в Нантакете?"
  },
  {
    "id": 72,
    "audio": "/audio/z_072.mp3",
    "text": "За кем в погоню отправились индейцы?"
  },
  {
    "id": 73,
    "audio": "/audio/z_073.mp3",
    "text": "В кого надо  было швырять булыжниками?"
  },
  {
    "id": 74,
    "audio": "/audio/z_074.mp3",
    "text": "Какой вопрос возник?"
  },
  {
    "id": 75,
    "audio": "/audio/z_075.mp3",
    "text": "Дно чего обшарил герой?"
  },
  {
    "id": 76,
    "audio": "/audio/z_076.mp3",
    "text": "Где хмурилось небо?"
  },
  {
    "id": 77,
    "audio": "/audio/z_077.mp3",
    "text": "О чём надо осведомиться?"
  },
  {
    "id": 78,
    "audio": "/audio/z_078.mp3",
    "text": "Как выглядело сие заведение?"
  },
  {
    "id": 79,
    "audio": "/audio/z_079.mp3",
    "text": "Как называлась гостиница?"
  },
  {
    "id": 80,
    "audio": "/audio/z_080.mp3",
    "text": "Звон чего доносился изнутри?"
  }
]